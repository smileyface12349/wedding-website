@using WeddingWebsite.Data.Models
@using WeddingWebsite.Components.Elements
@using WeddingWebsite.Components.Containers
@using WeddingWebsite.Models.Accounts
@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Models.Theme
@using WeddingWebsite.Models.WebsiteConfig
@using WeddingWebsite.Services

@inject IConfigProvider ConfigProvider
@inject IStringProvider StringProvider
@inject ISeatingPlanService SeatingPlanService

<div class="guests-list">
    @foreach (var guest in Guests)
    {
        <Box>
            <div class="guest">
                @if (Config.OptionalFeatures.SeatingPlan.IsActive() && Tables.TryGetValue(guest.Id, out var table) && table != null)
                {
                    <div class="guest-name-and-table">
                        <p class="guest-name">@guest.Name.Full</p>
                        <p class="guest-table">@table.Name</p>
                    </div>
                }
                else
                {
                    <p class="guest-name-only">@guest.Name.Full</p>
                }
                @if (Config.OptionalFeatures.Rsvp.IsActive())
                {
                    var url = $"/rsvp/{guest.Id}";
                    @switch (guest.RsvpStatus)
                    {
                        case RsvpStatus.NotResponded:
                            <LinkButton Url="@url">@StringProvider.Rsvp</LinkButton>
                            break;
                        default:
                            <CascadingValue Value="GreyButtonTheme">
                                <LinkButton Url="@url">@StringProvider.ViewRsvp</LinkButton>
                            </CascadingValue>
                            break;
                    }
                }
                else
                {
                    <button class="rsvp-disabled-button" disabled>@StringProvider.Rsvp</button>
                }
            </div>
        </Box>
        <div style="margin-bottom: 10px"></div>
    }
</div>

@code {
    [Parameter]
    public required IEnumerable<GuestWithId> Guests { get; set; }
    
    [CascadingParameter]
    private SectionTheme? Theme { get; set; }
    
    private SectionTheme? GreyButtonTheme => Theme == null ? null : Theme with { Primary = new Colour(200, 200, 200) };
    
    private Dictionary<string, SeatingPlanTable?> Tables { get; set; } = new Dictionary<string, SeatingPlanTable?>();
    
    private IWebsiteConfig Config { get; set; } = IConfigProvider.DefaultConfig;
    
    protected override async Task OnInitializedAsync()
    {
        Config = await ConfigProvider.GetConfigAsync();

        if (Config.OptionalFeatures.SeatingPlan.IsActive())
        {
            foreach (var guest in Guests)
            {  
                var table = SeatingPlanService.GetTableForGuest(guest.Id);
                Tables[guest.Id] = table;
            }
        }
    }
}