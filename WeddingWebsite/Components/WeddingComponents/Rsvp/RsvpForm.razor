@using WeddingWebsite.Components.Dialogs
@using WeddingWebsite.Components.Elements
@using WeddingWebsite.Components.Sections
@using WeddingWebsite.Data.Models
@using WeddingWebsite.Models.Accounts
@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Models.People
@using WeddingWebsite.Models.Theme
@using WeddingWebsite.Models.WebsiteConfig
@using WeddingWebsite.Models.WebsiteElement
@using WeddingWebsite.Services
@using Section = WeddingWebsite.Components.Sections.Section

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IWebsiteConfig Config
@inject IWeddingDetails WeddingDetails
@inject IStringProvider StringProvider
@inject NavigationManager NavigationManager
@inject IRsvpForm RsvpConfig
@inject IAdminService AdminService
@inject IDialogService DialogService

<PageTitle>@StringProvider.Rsvp</PageTitle>

@if (Guest == null)
{
    <p style="margin-top: 200px; text-align: center;">@StringProvider.YouSeemABitLost</p>
    return;
}

<CascadingValue TValue="SectionTheme" Value="ThemeNoBackground">
    <Section>
        <div class="form">
            <h1>@StringProvider.Rsvp for @Guest.Name</h1>
            @if (ReadOnly)
            {
                <p>@StringProvider.RsvpAlreadySubmitted(WeddingDetails.GetContactMethod(ContactReason.Attendance)?.Text)</p>
            }
            else if (EditMode)
            {
                <p>You may edit this RSVP on behalf of this guest.</p>
            }
            else
            {
                <p>@StringProvider.RsvpFormDescription</p>
                @if (WeddingDetails.GetContactMethod(ContactReason.Attendance) != null)
                {
                    <p><i>@StringProvider.RsvpFormDescriptionContact(WeddingDetails.GetContactMethod(ContactReason.Attendance)?.Text)</i></p>
                }
            }
            
            <h2>@StringProvider.RsvpAttendanceQuestion<span class="required-asterisk">*</span></h2>
            @if (RsvpConfig.LongAttendanceResponses)
            {
                <MudRadioGroup T="bool?" @bind-Value="IsAttending" Disabled="ReadOnly" UserAttributes="@(new Dictionary<string, object>{{"aria-required", "true"}})">
                    <MudRadio T="bool?" Value="true" Color="Color.Primary">@StringProvider.RsvpLongYes</MudRadio>
                    <MudRadio T="bool?" Value="false" Color="Color.Primary">@StringProvider.RsvpLongNo</MudRadio>
                </MudRadioGroup>
            }
            else
            {
                <YesOrNoToggleGroup @bind-Value="IsAttending" ReadOnly="ReadOnly"/>
            }
            
            @if (IsAttending == true)
            {
                @if (StringProvider.RsvpYesDescription != null) { <p>@StringProvider.RsvpYesDescription</p> }
                <RsvpFormQuestions UserId="@UserId" Guest="@Guest" Questions="RsvpConfig.YesQuestions" IsAttending="true" ReadOnly="ReadOnly" EditMode="EditMode" />
            }
            else if (IsAttending == false)
            {
                @if (StringProvider.RsvpNoDescription != null) { <p>@StringProvider.RsvpNoDescription</p> }
                <RsvpFormQuestions UserId="@UserId" Guest="@Guest" Questions="RsvpConfig.NoQuestions" IsAttending="false" ReadOnly="ReadOnly" EditMode="EditMode" />
            }
        </div>
        
    </Section>
</CascadingValue>

<style>
    body {
        @(Theme?.Background.GetBackgroundCss() ?? Config.Colours.Surface.GetBackgroundCss()) !important;
    }
</style>

@code {
    [Inject]
    public required IAccountService AccountService { get; set; }
    
    [Parameter]
    public required string GuestId { get; set; }

    [Parameter] 
    public string? UserId { get; set; }

    private bool? IsAttending { get; set; }
    private bool ReadOnly { get; set; } = false;
    private bool EditMode { get; set; } = false;
    
    private GuestWithId? Guest { get; set; }
    private SectionTheme? Theme => Config.RsvpConfig.Theme;
    private SectionTheme? ThemeNoBackground
    {
        get
        {
            if (Theme != null) return Theme with { Background = new NoBackground() };
            return null;
        }
    }

    private async Task GetGuest()
    {
        if (UserId != null)
        {
            Guest = AdminService.GetGuest(UserId, GuestId);
        }
        else
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity is not { IsAuthenticated: true })
            {
                return;
            }
            
            var guests = AccountService.GetOwnGuests(user);
            Guest = guests.FirstOrDefault(g => g.Id == GuestId);
        }
    }
    
    protected override async Task OnInitializedAsync()
    {
        await GetGuest();

        if (Guest == null)
        {
            NavigationManager.NavigateTo("/rsvp");
            return;
        }

        if (Guest.Rsvp != RsvpStatus.NotResponded)
        {
            if (UserId == null)
            {
                ReadOnly = true;
            }
            else
            {
                EditMode = true;
            }
            IsAttending = Guest.Rsvp == RsvpStatus.Yes;
        }
    }
}
