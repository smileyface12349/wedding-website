@page "/Admin"
@using WeddingWebsite.Components.Admin
@using WeddingWebsite.Components.Layouts
@using WeddingWebsite.Models.ConfigInterfaces

@attribute [Authorize(Roles = "Admin")]

@layout SimpleLayout

@inject IStringProvider StringProvider

<PageTitle>@StringProvider.PageTitle("Admin Page")</PageTitle>

<h1>Admin Page</h1>

<div class="links-container">
    <p>Links:</p>
    <a href="/account/register" role="button" class="button">New Account</a>
    <a href="/admin/stats" role="button" class="button">Stats</a>
    <a href="/admin/email/compose" role="button" class="button">Email</a>
    <a href="/todo" role="button" class="button">To-Do List</a>
    <a href="/seatingplan" role="button" class="button">Seating Plan</a>
</div>

<h2>Recent Activity</h2>
<p>Check out what's been happening recently. Some events are hidden by default.</p>
<RecentActivity/>

<h2>User Accounts</h2>
<p>In this section you can view all of the accounts and update details.</p>
<AccountList/>

<a class="button grey-button" href="/">Back to Home</a>

