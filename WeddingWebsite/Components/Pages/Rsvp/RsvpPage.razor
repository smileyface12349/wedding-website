@page "/rsvp/{GuestId}"

@using WeddingWebsite.Components.WeddingComponents.Rsvp
@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Services

@inject IConfigProvider ConfigProvider
@inject NavigationManager NavigationManager

@attribute [Authorize]

@rendermode InteractiveServer

<RsvpForm GuestId="@GuestId"/>

@code {

    [Parameter]
    public required string GuestId { get; set; }
    
    private IWebsiteConfig Config { get; set; } = IConfigProvider.DefaultConfig;
    
    protected override void OnInitialized()
    {
        Config = ConfigProvider.GetConfig();
        
        if (!Config.OptionalFeatures.Rsvp.IsActive())
        {
            NavigationManager.NavigateTo("/");
        }
    }

}