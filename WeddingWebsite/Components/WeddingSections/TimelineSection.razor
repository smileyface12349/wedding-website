@using WeddingWebsite.Components.Sections
@using WeddingWebsite.Components.WeddingComponents
@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Services

@inject IConfigProvider ConfigProvider
@inject IStringProvider StringProvider

@if (WeddingDetails is null)
{
    <p>Loading...</p>
    return;
}

<Section Padding="@ShowHeading" Id="timeline">
    @if (ShowHeading) {
        <SectionHeading>@StringProvider.OrderOfTheDay</SectionHeading>
    }
    <WeddingTimeline Events="WeddingDetails.Events" AccommodationDetails="WeddingDetails.AccommodationDetails" ShowTravelDirections="ShowTravelDirections"/>
</Section>

@code {
    [Parameter]
    public bool ShowHeading { get; set; } = false;
    
    [Parameter]
    public bool ShowTravelDirections { get; set; } = true;
    
    private IWeddingDetails? WeddingDetails { get; set; }
    
    protected override void OnInitialized()
    {
        WeddingDetails = ConfigProvider.GetDetails();
    }
}
